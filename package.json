{
  "name": "heapify",
  "version": "0.6.0",
  "description": "Blazing fast priority queue",
  "repository": {
    "type": "git",
    "url": "git://github.com/luciopaiva/heapify.git"
  },
  "main": "heapify.js",
  "browser": "heapify.js",
  "module": "heapify.mjs",
  "types": "heapify.d.ts",
  "scripts": {
    "test": "vitest --coverage",
    "integration": "npm run build:prod --silent && cd test/integration && ts-node --project scripts/run.tsconfig.json scripts/run.ts",
    "count": "cloc src/heapify.ts",
    "bench": "node benchmark/index.mjs",
    "lint": "eslint .",
    "clean": "rm -fr dist",
    "build": "npm run clean && vite build",
    "build:dev": "npm run clean && vite build --mode development",
    "build:prod": "npm run clean && vite build",
    "watch": "vite build --watch",
    "prepublishOnly": "ts-node ../scripts/prepublish.ts",
    "prerelease": "ts-node scripts/prerelease.ts",
    "release": "ENABLE_PUBLISH=true npm publish ./dist --dry-run"
  },
  "keywords": [
    "priority queue",
    "queue",
    "heap",
    "minheap",
    "maxheap",
    "binary heap",
    "heapsort"
  ],
  "author": {
    "name": "Lucio Paiva",
    "url": "https://luciopaiva.com"
  },
  "homepage": "https://github.com/luciopaiva/heapify",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "^22.19.13",
    "@vitest/coverage-v8": "^4.0.18",
    "cloc": "^2.5.1",
    "codecov": "^3.6.5",
    "eslint": "^10.0.2",
    "fastpriorityqueue": "0.6.3",
    "flatqueue": "1.1.0",
    "globals": "^17.4.0",
    "google-closure-library": "20200830.0.0",
    "tinyqueue": "2.0.3",
    "ts-node": "^10.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
